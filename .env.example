# ════════════════════════════════════════════════════════════════════
#  CourseBot — environment variables
# ════════════════════════════════════════════════════════════════════
#
#  MUHIM: bu yerda FAQAT texnik sozlamalar (sir kerak bo'lganlari).
#
#  Biznes sozlamalar (kanal_id, admin_group_id, narx, ball miqdori,
#  diskussiya guruhi, izoh limitlari) `Setting` jadvalida saqlanadi va
#  admin panel orqali o'zgartiriladi. Ular bu yerda EMAS.
#  Ro'yxati pastda izohda berilgan.
# ════════════════════════════════════════════════════════════════════


# ──────────── 1. APP ────────────
NODE_ENV=development          # development | production
PORT=3000                     # NestJS HTTP port (admin panel API uchun)


# ──────────── 2. DATABASE ────────────
# Lokalda docker-compose ishlatilganda shu URL to'g'ri keladi.
# Productionda: postgresql://USER:STRONG_PASSWORD@DB_HOST:5432/DB_NAME?schema=public
DATABASE_URL=postgresql://postgres:Ziyodilloh_06@localhost:5432/coursebot?schema=public


# ──────────── 3. REDIS (BullMQ uchun) ────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=               # bo'sh qoldirsangiz parolsiz ulanadi


# ──────────── 4. TELEGRAM BOT ────────────
# BotFather'dan oling: https://t.me/BotFather → /newbot
BOT_TOKEN=1234567890:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bot username (@ siz!) — referral linkida ishlatiladi:
# https://t.me/<BOT_USERNAME>?start=ref_<userId>
BOT_USERNAME=mycourse_bot

# Polling (development uchun) yoki webhook (production)
BOT_MODE=polling
# BOT_MODE=webhook
# BOT_WEBHOOK_URL=https://example.com/bot/webhook
# BOT_WEBHOOK_SECRET=long-random-string-min-32-chars


# ──────────── 5. STORAGE CHAT ────────────
# Welcome video upload qilinganda Telegram'ga "qo'yib turish" uchun chat.
# Bot SHU CHATGA admin bo'lishi shart (yoki a'zo va yozish huquqi bor).
# Tavsiya: alohida private kanal yaratib, faqat bot va siz bo'ling.
# chat_id ni olish: kanalga test xabar yuborib @username_to_id_bot orqali.
STORAGE_CHAT_ID=-1001234567890


# ──────────── 6. JWT (admin panel auth) ────────────
# CHALG'ITMASLIK uchun productionda OZIRGI o'zgartiring.
# Tavsiya: openssl rand -base64 48
JWT_SECRET=change_this_to_a_strong_random_secret_min_32_chars
JWT_EXPIRES_IN=7d


# ──────────── 7. DEFAULT ADMIN (seed uchun) ────────────
# `npm run prisma:seed` ishga tushganda yaratiladi.
# Birinchi login dan keyin parolingizni o'zgartiring (Settings → Profil).
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123


# ════════════════════════════════════════════════════════════════════
#  QO'SHIMCHA: BIZNES SOZLAMALARI (DB'da, .env'da EMAS!)
# ════════════════════════════════════════════════════════════════════
#
#  Bu sozlamalar `Setting` jadvalida saqlanadi va admin panel orqali
#  to'ldiriladi: http://localhost:3000 → Login → Kontent / Sozlamalar
#
#  ───── To'lov & kanal ─────
#    admin_group_id          — chek tushadigan ADMIN GURUH chat_id (-100…)
#                               Bot bu guruhda admin bo'lishi shart.
#    channel_id              — yopiq KANAL chat_id (-100…)
#                               Bot kanal admin bo'lishi shart (a'zo qo'shadi).
#    channel_invite_link     — kanal default invite link (zaxira uchun).
#                               Tasdiqlanganda bot yangi 1-martalik link
#                               yaratadi, bu esa fallback.
#    welcome_video_file_id   — welcome video file_id (admin paneldan upload).
#    welcome_text            — welcome matni (HTML format).
#    card_number, card_holder — to'lov uchun karta ma'lumotlari.
#    course_price            — narx so'mda (masalan: "500000").
#
#  ───── Gamifikatsiya ─────
#    discussion_group_id     — yopiq kanalga ulangan DISKUSSIYA GURUHI
#                               chat_id (-100…). Bot guruhda admin bo'lishi
#                               shart, /setprivacy → Disable.
#    gamification_enabled    — "true" yoki "false" (kalit-pulli o'chirish)
#    points_per_referral_start    — referral start bossa (default 10)
#    points_per_referral_purchase — referral kursni sotib olsa (default 50)
#    points_per_comment           — izoh yozsa (default 10)
#    points_per_reaction          — reaksiya bossa (default 10)
#    min_comment_length      — anti-spam: izohning minimal uzunligi (5)
#    max_comments_per_day    — anti-spam: kuniga max izoh soni (10)
#
#  Telegram'da chat_id'larni olish:
#    1. Bot yoki @username_to_id_bot ga kanaldan/guruhdan xabar forward qiling
#    2. Yoki guruhga @userinfobot qo'shing va /id yozing
#    3. Yopiq kanal/guruh ID'lari -100 bilan boshlanadi (masalan -1001234567890)
#
#  Birinchi marta sozlash tartibi:
#    1) Bot'ni yarating (@BotFather)
#    2) Yopiq kanal yarating + bot'ni admin qiling
#    3) Kanalga discussion guruh ulang + bot'ni guruhda admin qiling
#    4) Alohida admin guruh yarating (cheklar tushadigan) + bot admin
#    5) STORAGE_CHAT_ID uchun alohida private kanal yarating + bot admin
#    6) `npm run prisma:seed` → admin yarating
#    7) Admin panelga kiring → Kontent → barcha settings'ni to'ldiring
# ════════════════════════════════════════════════════════════════════
