# App
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/coursebot?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Bot
BOT_TOKEN=xxxxxxxxxxxxxxxx
BOT_USERNAME=mycourse_bot
BOT_MODE=polling
# BOT_MODE=webhook
# BOT_WEBHOOK_URL=https://example.com/bot/webhook
# BOT_WEBHOOK_SECRET=some-strong-random-string

# Storage chat (file_id olish uchun, bot a'zo bo'lishi shart)
STORAGE_CHAT_ID=-1001234567890

# JWT (admin panel uchun)
JWT_SECRET=super_secret_change_this_in_production
JWT_EXPIRES_IN=7d

# Default admin (seed uchun)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
