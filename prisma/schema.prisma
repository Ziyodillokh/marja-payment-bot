// CourseBot Prisma schema
// Bot va admin panel ikkalasi ham shu DB'dan foydalanadi.
//
// PRIMARY KEY: barcha modellarda CUID ishlatamiz (24 belgi, sortable, URL-safe).
// UUID o'rniga CUID afzalliklari:
//   - Qisqaroq (24 vs 36 char)
//   - Vaqt bo'yicha tartiblanadi (DB index uchun yaxshi)
//   - URL-friendly

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────── ENUMS ────────────────

enum UserStatus {
  NEW
  PHONE_PROVIDED
  PAYMENT_PENDING
  APPROVED
  REJECTED
  BLOCKED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BroadcastFilter {
  ALL
  PAID
  UNPAID
  PENDING
  SPECIFIC
}

enum BroadcastStatus {
  PENDING
  SENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum TriggerType {
  AFTER_START_NO_PAYMENT
  AFTER_PHONE_NO_PAYMENT
  AFTER_PAYMENT_NO_APPROVAL
}

enum PointsTransactionType {
  REFERRAL_START
  REFERRAL_PURCHASE
  COMMENT
  REACTION
  REACTION_REMOVED
  ADMIN_ADJUSTMENT
}

// ──────────────── MODELS ────────────────

model User {
  id               String     @id @default(cuid())
  telegramId       BigInt     @unique
  username         String?
  firstName        String?
  lastName         String?
  phoneNumber      String?
  languageCode     String?
  status           UserStatus @default(NEW)
  startedAt        DateTime   @default(now())
  paymentStartedAt DateTime?
  approvedAt       DateTime?

  // ───── Gamifikatsiya ─────
  points           Int        @default(0)
  referredById     String?
  referredBy       User?      @relation("UserReferrals", fields: [referredById], references: [id])
  referrals        User[]     @relation("UserReferrals")

  pointsTransactions PointsTransaction[]
  reactionLogs       ReactionLog[]
  commentLogs        CommentLog[]

  // ───── UTM tracking (first-touch attribution) ─────
  utmSourceId      String?
  utmSource        UtmSource? @relation(fields: [utmSourceId], references: [id])
  utmRawParam      String?    // raw start parameter (debugging va kelajakdagi parametrlar uchun)

  payments         Payment[]
  autoMessageLogs  AutoMessageLog[]

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([points])
  @@index([referredById])
  @@index([utmSourceId])
  @@index([utmSourceId, status])
  @@index([utmSourceId, createdAt])
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount          Decimal       @db.Decimal(12, 2)
  photoFileId     String
  status          PaymentStatus @default(PENDING)
  reviewedById    String?
  reviewedAt      DateTime?
  rejectionReason String?
  groupChatId     BigInt?
  groupMessageId  Int?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([userId])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Broadcast {
  id          String          @id @default(cuid())
  text        String          @db.Text
  mediaFileId String?
  mediaType   String?
  parseMode   String?         @default("HTML")
  filterType  BroadcastFilter
  userIds     String[]        @default([])
  status      BroadcastStatus @default(PENDING)
  totalCount  Int             @default(0)
  sentCount   Int             @default(0)
  failedCount Int             @default(0)
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdById String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt @default(now())

  recipients  BroadcastRecipient[]

  @@index([status])
  @@index([createdAt])
}

model BroadcastRecipient {
  id          String    @id @default(cuid())
  broadcastId String
  broadcast   Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  userId      String
  telegramId  BigInt
  messageId   Int?
  status      String    @default("PENDING")
  errorReason String?
  sentAt      DateTime?
  editedAt    DateTime?

  @@unique([broadcastId, userId])
  @@index([broadcastId])
  @@index([userId])
}

model AutoMessage {
  id           String      @id @default(cuid())
  name         String
  triggerType  TriggerType
  triggerAfter Int
  text         String      @db.Text
  mediaFileId  String?
  mediaType    String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  sentLogs     AutoMessageLog[]

  @@index([triggerType, isActive])
}

model AutoMessageLog {
  id            String      @id @default(cuid())
  autoMessageId String
  autoMessage   AutoMessage @relation(fields: [autoMessageId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sentAt        DateTime    @default(now())

  @@unique([autoMessageId, userId])
  @@index([userId])
}

// ──────────────── GAMIFIKATSIYA ────────────────

model PointsTransaction {
  id               String                @id @default(cuid())
  userId           String
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount           Int
  type             PointsTransactionType
  description      String?
  relatedUserId    String?
  relatedMessageId BigInt?
  createdAt        DateTime              @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([type])
  // Idempotency: bitta referee uchun bitta REFERRAL_PURCHASE
  @@unique([userId, type, relatedUserId], name: "uniq_referral_purchase")
}

model ReactionLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatId        BigInt
  messageId     BigInt
  emoji         String
  isActive      Boolean  @default(true)
  pointsAwarded Int      @default(0)
  firstSetAt    DateTime @default(now())
  lastChangedAt DateTime @updatedAt

  @@unique([userId, chatId, messageId])
  @@index([chatId, messageId])
}

// ──────────────── UTM TRACKING ────────────────

model UtmSource {
  id          String   @id @default(cuid())
  code        String   @unique          // qisqa kod: "fb", "site1", "instagram"
  name        String                    // ko'rsatish nomi: "Facebook Ads"
  description String?
  isActive    Boolean  @default(true)
  createdById String?                   // qaysi admin yaratgan
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]

  @@index([code])
  @@index([isActive])
}

model CommentLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatId        BigInt
  messageId     BigInt
  threadId      BigInt?
  pointsAwarded Int      @default(0)
  createdAt     DateTime @default(now())

  @@unique([chatId, messageId])
  @@index([userId, createdAt])
}
